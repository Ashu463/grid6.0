# ── Copy this to .env in your root folder ─────
# Never commit real secrets — use this as a template

NODE_ENV=production

# Postgres
POSTGRES_USER=shield
POSTGRES_PASSWORD=shield_secret
POSTGRES_DB=api_shield

# JWT
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/gateway/auth/google/callback

# Payment
PAYMENT_SECRET_KEY=
PAYMENT_PROVIDER=stripe

# Session TTL in seconds (24h default)
SESSION_TTL=86400
